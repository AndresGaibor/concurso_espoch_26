    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "date-fns": "^4.1.0",
    "install": "^0.13.0",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
